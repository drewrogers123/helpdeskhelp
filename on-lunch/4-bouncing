data:text/html,<html><head><style>*{margin:0;padding:0;box-sizing:border-box}body{background:%23000;overflow:hidden;width:100vw;height:100vh}.b{position:absolute;font-family:sans-serif;font-size:8vw;font-weight:900;white-space:nowrap;user-select:none}</style></head><body><script>const c=['%23ff4444','%23ff8800','%23ffee00','%2344ff44','%2300ccff','%23aa44ff','%23ff44aa','%23ffffff'];const bs=[];for(let i=0;i<4;i++){const el=document.createElement('div');el.className='b';el.textContent='ON LUNCH';document.body.appendChild(el);const a=(i/4)*Math.PI*2;const s=1.5+i*0.4;bs.push({el,x:100+i*120,y:80+i*60,dx:Math.cos(a)*s,dy:Math.sin(a)*s,ci:i});el.style.color=c[i%c.length]}function rc(x){let r;do{r=c[Math.floor(Math.random()*c.length)]}while(r===x);return r}function a(){const W=window.innerWidth,H=window.innerHeight;for(const b of bs){const w=b.el.offsetWidth,h=b.el.offsetHeight;b.x+=b.dx;b.y+=b.dy;let hit=false;if(b.x+w>=W){b.x=W-w;b.dx=-Math.abs(b.dx);hit=true}if(b.x<=0){b.x=0;b.dx=Math.abs(b.dx);hit=true}if(b.y+h>=H){b.y=H-h;b.dy=-Math.abs(b.dy);hit=true}if(b.y<=0){b.y=0;b.dy=Math.abs(b.dy);hit=true}if(hit)b.el.style.color=rc(b.el.style.color);b.el.style.left=b.x+'px';b.el.style.top=b.y+'px'}requestAnimationFrame(a)}a()</script></body></html>
