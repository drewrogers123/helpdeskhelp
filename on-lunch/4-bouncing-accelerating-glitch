data:text/html,<!DOCTYPE html><html><head><style>*{margin:0;padding:0;box-sizing:border-box}body{background:%23000;overflow:hidden;width:100vw;height:100vh}.blob{position:absolute;font-family:sans-serif;font-size:8vw;font-weight:900;white-space:nowrap;user-select:none;letter-spacing:-0.02em}</style></head><body><script>const colors=['%23ff4444','%23ff8800','%23ffee00','%2344ff44','%2300ccff','%23aa44ff','%23ff44aa','%23ffffff'];const COUNT=4;const blobs=[];const startTime=Date.now();for(let i=0;i<COUNT;i++){const el=document.createElement('div');el.className='blob';el.textContent='ON LUNCH';document.body.appendChild(el);const angle=(i/COUNT)*Math.PI*2;const speed=1.5+i*0.4;blobs.push({el,x:100+i*120,y:80+i*60,dx:Math.cos(angle)*speed,dy:Math.sin(angle)*speed,colorIndex:i,glitchTimer:0,glitching:false});el.style.color=colors[i%colors.length]}function randomColor(exclude){let c;do{c=colors[Math.floor(Math.random()*colors.length)]}while(c===exclude);return c}function applyGlitch(blob){const el=blob.el;const offset=3+Math.random()*5;el.style.textShadow=`${-offset}px 0 rgba(255,0,0,0.85), ${offset}px 0 rgba(0,200,255,0.85)`;el.style.transform=`skewX(${(Math.random()-0.5)*8}deg) scaleX(${0.95+Math.random()*0.1})`}function clearGlitch(blob){blob.el.style.textShadow='none';blob.el.style.transform='none'}function animate(){const W=window.innerWidth;const H=window.innerHeight;const elapsed=(Date.now()-startTime)/1000;const speedMult=1+elapsed/60;for(const blob of blobs){const w=blob.el.offsetWidth;const h=blob.el.offsetHeight;blob.x+=blob.dx*speedMult;blob.y+=blob.dy*speedMult;let hit=false;if(blob.x+w>=W){blob.x=W-w;blob.dx=-Math.abs(blob.dx);hit=true}if(blob.x<=0){blob.x=0;blob.dx=Math.abs(blob.dx);hit=true}if(blob.y+h>=H){blob.y=H-h;blob.dy=-Math.abs(blob.dy);hit=true}if(blob.y<=0){blob.y=0;blob.dy=Math.abs(blob.dy);hit=true}if(hit){blob.el.style.color=randomColor(blob.el.style.color)}const glitchChance=0.004+elapsed*0.00015;if(!blob.glitching&&Math.random()<glitchChance){blob.glitching=true;blob.glitchTimer=3+Math.floor(Math.random()*8);applyGlitch(blob)}else if(blob.glitching){blob.glitchTimer--;if(blob.glitchTimer%2===0)applyGlitch(blob);else clearGlitch(blob);if(blob.glitchTimer<=0){blob.glitching=false;clearGlitch(blob)}}blob.el.style.left=blob.x+'px';blob.el.style.top=blob.y+'px'}requestAnimationFrame(animate)}animate()</script></body></html>
