data:text/html,<html><head><style>*{margin:0;padding:0;box-sizing:border-box}body{background:%23000;overflow:hidden;width:100vw;height:100vh}%23t{position:absolute;font-family:sans-serif;font-size:10vw;font-weight:900;white-space:nowrap;user-select:none;letter-spacing:-2px;}</style></head><body><div id=t>ON LUNCH</div><script>const e=document.getElementById('t'),c=['%23ff4444','%23ff8800','%23ffee00','%2344ff44','%2300ccff','%23aa44ff','%23ff44aa','%23ffffff'];let i=0,x=100,y=100,dx=2.2,dy=2.0,gt=0,gl=false;e.style.color=c[0];function a(){const W=window.innerWidth,H=window.innerHeight,w=e.offsetWidth,h=e.offsetHeight;x+=dx;y+=dy;let b=false;if(x+w>=W){x=W-w;dx=-Math.abs(dx);b=true}if(x<=0){x=0;dx=Math.abs(dx);b=true}if(y+h>=H){y=H-h;dy=-Math.abs(dy);b=true}if(y<=0){y=0;dy=Math.abs(dy);b=true}if(b){i++;e.style.color=c[i%c.length]}/* Subtle trigger: 1% chance */if(!gl&&Math.random()<0.01){gl=true;gt=Math.floor(Math.random()*6)+2}if(gl){/* Sharp, tight RGB split */const o=2+Math.random()*3;const jit=(Math.random()-0.5)*4;if(gt%2===0){e.style.textShadow=`${o}px 0 rgba(255,0,0,0.7), -${o}px 0 rgba(0,255,255,0.7)`;e.style.transform=`translateX(${jit}px)`;/* Occasional horizontal slice/clip */if(Math.random()>0.5){e.style.clipPath=`inset(${Math.random()*100}% 0 ${Math.random()*100}% 0)`;}}else{e.style.textShadow='none';e.style.transform='none';e.style.clipPath='none'}gt--;if(gt<=0){gl=false;e.style.textShadow='none';e.style.transform='none';e.style.clipPath='none'}}e.style.left=x+'px';e.style.top=y+'px';requestAnimationFrame(a)}a()</script></body></html>
