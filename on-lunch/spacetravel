data:text/html,<html><head><style>*{margin:0;padding:0}body{background:%23000;overflow:hidden;width:100vw;height:100vh}canvas{display:block}%23t{position:absolute;top:50%25;left:50%25;transform:translate(-50%25,-50%25);font-family:sans-serif;font-size:10vw;font-weight:900;color:%23fff;white-space:nowrap;text-align:center;text-shadow:0 0 30px %23fff,0 0 60px %23aaf}</style></head><body><canvas id=c></canvas><div id=t>ON LUNCH</div><script>const cv=document.getElementById('c'),ctx=cv.getContext('2d');function resize(){cv.width=window.innerWidth;cv.height=window.innerHeight}resize();window.onresize=resize;const N=200;const stars=Array.from({length:N},()=>({x:(Math.random()-.5)*2000,y:(Math.random()-.5)*2000,z:Math.random()*2000}));function draw(){const W=cv.width,H=cv.height;ctx.fillStyle='rgba(0,0,0,0.2)';ctx.fillRect(0,0,W,H);const cx=W/2,cy=H/2;for(const s of stars){s.z-=6;if(s.z<=0)Object.assign(s,{x:(Math.random()-.5)*2000,y:(Math.random()-.5)*2000,z:2000});const sx=cx+s.x/s.z*W;const sy=cy+s.y/s.z*H;const r=Math.max(0.5,(1-s.z/2000)*3);const bright=Math.floor((1-s.z/2000)*255);ctx.fillStyle=`rgb(${bright},${bright},${bright})`;ctx.beginPath();ctx.arc(sx,sy,r,0,Math.PI*2);ctx.fill()}requestAnimationFrame(draw)}draw()</script></body></html>
